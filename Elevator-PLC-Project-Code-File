🔹 1. UDT (WITH LOGGING)
TYPE UDT_Lift :
STRUCT
    // Floors
    CurrentFloor : INT;
    TargetFloor  : INT;

    // Requests
    Req : STRUCT
        F1 : BOOL;
        F2 : BOOL;
        F3 : BOOL;
        F4 : BOOL;
    END_STRUCT;

    // Inputs
    Input : STRUCT
        F1_Up     : BOOL;
        F2_Up     : BOOL;
        F2_Down   : BOOL;
        F3_Up     : BOOL;
        F3_Down   : BOOL;
        F4_Down   : BOOL;

        Cab_F1    : BOOL;
        Cab_F2    : BOOL;
        Cab_F3    : BOOL;
        Cab_F4    : BOOL;

        Door_Open : BOOL;
        Door_Close: BOOL;

        F1_Sensor : BOOL;
        F2_Sensor : BOOL;
        F3_Sensor : BOOL;
        F4_Sensor : BOOL;

        Door_Sensor : BOOL;

        Drive_Ready : BOOL;
        Drive_Fault : BOOL;
    END_STRUCT;

    // Outputs
    Output : STRUCT
        Start     : BOOL;
        Direction : BOOL;
        Speed     : INT;

        Door_Open  : BOOL;
        Door_Close : BOOL;
    END_STRUCT;

    // ===== STATUS + LOGGING =====
    StatusText     : STRING[50];
    LastStatusText : STRING[50];

    Log      : ARRAY[1..10] OF STRING[50];
    LogIndex : INT := 1;

END_STRUCT
END_TYPE

🔹 2. FB (FULL LOGIC)
Create: FB_LiftControl
FUNCTION_BLOCK FB_LiftControl

VAR_IN_OUT
    Lift : UDT_Lift;
END_VAR

VAR
    DoorTimer : TON;
END_VAR

🔹 3. REQUEST LOGIC
IF Lift.Input.F1_Up OR Lift.Input.Cab_F1 THEN Lift.Req.F1 := TRUE; END_IF;
IF Lift.Input.F2_Up OR Lift.Input.F2_Down OR Lift.Input.Cab_F2 THEN Lift.Req.F2 := TRUE; END_IF;
IF Lift.Input.F3_Up OR Lift.Input.F3_Down OR Lift.Input.Cab_F3 THEN Lift.Req.F3 := TRUE; END_IF;
IF Lift.Input.F4_Down OR Lift.Input.Cab_F4 THEN Lift.Req.F4 := TRUE; END_IF;


🔹 4. CURRENT FLOOR
IF Lift.Input.F1_Sensor THEN Lift.CurrentFloor := 1; END_IF;
IF Lift.Input.F2_Sensor THEN Lift.CurrentFloor := 2; END_IF;
IF Lift.Input.F3_Sensor THEN Lift.CurrentFloor := 3; END_IF;
IF Lift.Input.F4_Sensor THEN Lift.CurrentFloor := 4; END_IF;

🔹 5. TARGET FLOOR
IF Lift.Req.F1 THEN Lift.TargetFloor := 1;
ELSIF Lift.Req.F2 THEN Lift.TargetFloor := 2;
ELSIF Lift.Req.F3 THEN Lift.TargetFloor := 3;
ELSIF Lift.Req.F4 THEN Lift.TargetFloor := 4;
ELSE
    Lift.TargetFloor := 0;
END_IF;

🔹 6. DRIVE CONTROL
// Direction
IF Lift.TargetFloor > Lift.CurrentFloor THEN
    Lift.Output.Direction := TRUE;
ELSIF Lift.TargetFloor < Lift.CurrentFloor THEN
    Lift.Output.Direction := FALSE;
END_IF;

// Start/Stop
IF (Lift.TargetFloor <> 0) AND 
   (Lift.TargetFloor <> Lift.CurrentFloor) AND 
   NOT Lift.Output.Door_Open THEN
    Lift.Output.Start := TRUE;
ELSE
    Lift.Output.Start := FALSE;
END_IF;

// Speed
Lift.Output.Speed := 1500;
IF ABS(Lift.TargetFloor - Lift.CurrentFloor) = 1 THEN
    Lift.Output.Speed := 500;
END_IF;

// Drive safety
IF Lift.Input.Drive_Fault OR NOT Lift.Input.Drive_Ready THEN
    Lift.Output.Start := FALSE;
END_IF;

🔹 7. ARRIVAL

IF Lift.CurrentFloor = Lift.TargetFloor THEN
    Lift.Output.Start := FALSE;

    CASE Lift.CurrentFloor OF
        1: Lift.Req.F1 := FALSE;
        2: Lift.Req.F2 := FALSE;
        3: Lift.Req.F3 := FALSE;
        4: Lift.Req.F4 := FALSE;
    END_CASE;
END_IF;

🔹 8. DOOR CONTROL
// Open
IF Lift.CurrentFloor = Lift.TargetFloor AND Lift.TargetFloor <> 0 THEN
    Lift.Output.Door_Open := TRUE;
END_IF;

// Timer
DoorTimer(IN := Lift.Output.Door_Open, PT := T#5s);

IF DoorTimer.Q THEN
    Lift.Output.Door_Open := FALSE;
    Lift.Output.Door_Close := TRUE;
END_IF;

// Safety
IF Lift.Input.Door_Sensor THEN
    Lift.Output.Door_Close := FALSE;
    Lift.Output.Door_Open := TRUE;
END_IF;

// Manual
IF Lift.Input.Door_Open THEN
    Lift.Output.Door_Open := TRUE;
    Lift.Output.Door_Close := FALSE;
END_IF;

IF Lift.Input.Door_Close THEN
    Lift.Output.Door_Close := TRUE;
    Lift.Output.Door_Open := FALSE;
END_IF;

🔹 9. INTERLOCKS
// No movement if door open
IF Lift.Output.Door_Open THEN
    Lift.Output.Start := FALSE;
END_IF;

// Prevent both door signals
IF Lift.Output.Door_Open AND Lift.Output.Door_Close THEN
    Lift.Output.Door_Close := FALSE;
END_IF;

🔹 10. STATUS MESSAGES

// Movement
IF Lift.TargetFloor > Lift.CurrentFloor THEN
    Lift.StatusText := CONCAT('Moving UP to Floor ', INT_TO_STRING(Lift.TargetFloor));
ELSIF Lift.TargetFloor < Lift.CurrentFloor THEN
    Lift.StatusText := CONCAT('Moving DOWN to Floor ', INT_TO_STRING(Lift.TargetFloor));
END_IF;

// Stop
IF Lift.CurrentFloor = Lift.TargetFloor AND Lift.TargetFloor <> 0 THEN
    Lift.StatusText := CONCAT('Stopped at Floor ', INT_TO_STRING(Lift.CurrentFloor));
END_IF;

// Door
IF Lift.Output.Door_Open THEN
    Lift.StatusText := 'Door Opening';
END_IF;

IF Lift.Output.Door_Close THEN
    Lift.StatusText := 'Door Closing';
END_IF;

🔹 11. LOGGING
IF Lift.StatusText <> '' AND Lift.StatusText <> Lift.LastStatusText THEN

    Lift.Log[Lift.LogIndex] := Lift.StatusText;

    Lift.LogIndex := Lift.LogIndex + 1;

    IF Lift.LogIndex > 10 THEN
        Lift.LogIndex := 1;
    END_IF;

END_IF;

// Store last message
Lift.LastStatusText := Lift.StatusText;
